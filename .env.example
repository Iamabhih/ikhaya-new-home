# ===========================================
# OZZ Cash & Carry - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# -------------------------------------------
# Supabase Configuration (Required)
# -------------------------------------------
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# -------------------------------------------
# Application Settings (Required)
# -------------------------------------------
# Your live website URL (no trailing slash)
VITE_APP_URL=http://localhost:8080

# Contact email displayed on the site
VITE_CONTACT_EMAIL=queries@yourdomain.com

# -------------------------------------------
# PayFast Configuration (Required for payments)
# -------------------------------------------
# Get these from https://www.payfast.co.za/merchant/settings
VITE_PAYFAST_MODE=sandbox
VITE_PAYFAST_MERCHANT_ID=your_merchant_id
VITE_PAYFAST_MERCHANT_KEY=your_merchant_key

# PayFast Passphrase (for Supabase edge functions only, NOT frontend)
# Set this in Supabase dashboard: Settings → Edge Functions → Secrets
# PAYFAST_PASSPHRASE=your_passphrase_here

# -------------------------------------------
# Bank Account Details (Optional - for EFT payments)
# -------------------------------------------
# VITE_BANK_NAME=your_bank_name
# VITE_BANK_ACCOUNT_HOLDER=your_account_holder
# VITE_BANK_ACCOUNT_NUMBER=your_account_number
# VITE_BANK_BRANCH_CODE=your_branch_code
# VITE_BANK_ACCOUNT_TYPE=your_account_type

# -------------------------------------------
# Supabase Edge Function Secrets
# -------------------------------------------
# Set these in Supabase Dashboard → Settings → Edge Functions → Secrets
# (NOT in this file — they are backend-only)
#
# RESEND_API_KEY=your_resend_api_key
# NOREPLY_EMAIL=noreply@yourdomain.com
# APP_URL=https://yourdomain.com
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
